<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>3D Bike Game</title>

<style>
body{
    margin:0;
    overflow:hidden;
}
canvas{
    display:block;
}
#speed{
    position:absolute;
    top:20px;
    left:20px;
    color:white;
    font-size:30px;
    font-family:Arial;
}
</style>

</head>

<body>

<div id="speed">0 km/h</div>

<script type="module">

import * as THREE from "https://cdn.jsdelivr.net/npm/three@0.165/build/three.module.js";

const scene=new THREE.Scene();
scene.background=new THREE.Color(0x87ceeb);

const camera=new THREE.PerspectiveCamera(
75,
window.innerWidth/window.innerHeight,
0.1,
1000
);

const renderer=new THREE.WebGLRenderer({antialias:true});
renderer.setSize(window.innerWidth,window.innerHeight);
renderer.shadowMap.enabled=true;
document.body.appendChild(renderer.domElement);

const light=new THREE.DirectionalLight(0xffffff,2);
light.position.set(10,20,10);
scene.add(light);

const ground=new THREE.Mesh(
new THREE.PlaneGeometry(500,500),
new THREE.MeshStandardMaterial({color:0x228B22})
);

ground.rotation.x=-Math.PI/2;
scene.add(ground);

const road=new THREE.Mesh(
new THREE.BoxGeometry(8,0.1,500),
new THREE.MeshStandardMaterial({color:0x333333})
);

road.position.y=0.05;
scene.add(road);

const bike=new THREE.Mesh(
new THREE.BoxGeometry(1,1,2),
new THREE.MeshStandardMaterial({color:"red"})
);

bike.position.y=0.6;
scene.add(bike);

camera.position.set(0,3,8);

let speed=0;

document.addEventListener("keydown",e=>{

if(e.key=="ArrowUp") speed+=0.05;
if(e.key=="ArrowDown") speed-=0.05;

});

function animate(){

requestAnimationFrame(animate);

bike.position.z-=speed;

camera.position.z=bike.position.z+8;
camera.lookAt(bike.position);

document.getElementById("speed").innerHTML=
Math.max(0,(speed*500).toFixed(0))+" km/h";

renderer.render(scene,camera);

}

animate();

</script>

</body>
</html>
