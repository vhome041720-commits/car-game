<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Low Graphic Car Game</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:#2f2f2f;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
font-family:Arial;
overflow:hidden;
}

canvas{
background:#4caf50;
border:4px solid white;
}
</style>

</head>
<body>

<canvas id="game" width="400" height="700"></canvas>

<script>

const canvas=document.getElementById("game");
const ctx=canvas.getContext("2d");

const road={
x:70,
width:260
};

let score=0;
let speed=6;
let gameOver=false;

const player={
x:180,
y:580,
w:40,
h:70,
color:"#1e88e5"
};

const keys={};

document.addEventListener("keydown",(e)=>{
keys[e.key]=true;

if(gameOver && e.key==="Enter"){
restart();
}
});

document.addEventListener("keyup",(e)=>{
keys[e.key]=false;
});

let enemies=[];

function createEnemy(){

let lane=Math.floor(Math.random()*3);

let x=road.x+30+lane*80;

enemies.push({
x:x,
y:-100,
w:40,
h:70,
color:"red"
});

}

setInterval(()=>{
if(!gameOver)
createEnemy();
},900);

function drawRoad(){

ctx.fillStyle="#555";
ctx.fillRect(road.x,0,road.width,700);

ctx.fillStyle="white";

for(let i=0;i<20;i++){

ctx.fillRect(196,i*50+roadOffset,8,30);

}

}

let roadOffset=0;

function drawPlayer(){

ctx.fillStyle=player.color;
ctx.fillRect(player.x,player.y,player.w,player.h);

ctx.fillStyle="#fff";
ctx.fillRect(player.x+8,player.y+10,24,15);

ctx.fillStyle="black";
ctx.fillRect(player.x-2,player.y+8,6,15);
ctx.fillRect(player.x+36,player.y+8,6,15);
ctx.fillRect(player.x-2,player.y+48,6,15);
ctx.fillRect(player.x+36,player.y+48,6,15);

}

function drawEnemies(){

for(let e of enemies){

ctx.fillStyle=e.color;
ctx.fillRect(e.x,e.y,e.w,e.h);

ctx.fillStyle="white";
ctx.fillRect(e.x+8,e.y+10,24,15);

ctx.fillStyle="black";
ctx.fillRect(e.x-2,e.y+8,6,15);
ctx.fillRect(e.x+36,e.y+8,6,15);
ctx.fillRect(e.x-2,e.y+48,6,15);
ctx.fillRect(e.x+36,e.y+48,6,15);

}
}

function update(){

if(gameOver)return;

roadOffset+=speed;

if(roadOffset>50)
roadOffset=0;

if(keys["ArrowLeft"])
player.x-=6;

if(keys["ArrowRight"])
player.x+=6;

if(player.x<road.x+10)
player.x=road.x+10;

if(player.x>road.x+road.width-player.w-10)
player.x=road.x+road.width-player.w-10;

for(let i=enemies.length-1;i>=0;i--){

let e=enemies[i];

e.y+=speed;

if(e.y>750){

enemies.splice(i,1);

score++;

if(score%10===0)
speed+=0.5;

}

if(player.x<e.x+e.w &&
player.x+player.w>e.x &&
player.y<e.y+e.h &&
player.y+player.h>e.y){

gameOver=true;

}

}

}

function drawScore(){

ctx.fillStyle="white";
ctx.font="22px Arial";
ctx.fillText("Score : "+score,15,30);

ctx.fillText("Speed : "+speed.toFixed(1),15,60);

}

function drawGameOver(){

ctx.fillStyle="rgba(0,0,0,0.7)";
ctx.fillRect(0,0,400,700);

ctx.fillStyle="white";
ctx.font="40px Arial";
ctx.fillText("GAME OVER",70,300);

ctx.font="24px Arial";
ctx.fillText("Score : "+score,135,350);

ctx.fillText("Press ENTER",110,410);

}

function loop(){

ctx.clearRect(0,0,400,700);

drawRoad();

update();

drawEnemies();

drawPlayer();

drawScore();

if(gameOver)
drawGameOver();

requestAnimationFrame(loop);

}

function restart(){

score=0;
speed=6;
gameOver=false;

player.x=180;

enemies=[];

}

loop();

</script>

</body>
</html>
