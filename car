<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>3D Car Game</title>

<style>
body{
    margin:0;
    overflow:hidden;
    background:#87CEEB;
}

#score{
    position:absolute;
    top:10px;
    left:10px;
    color:white;
    font-size:25px;
    font-family:Arial;
    z-index:100;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/three@0.166/build/three.min.js"></script>

</head>

<body>

<div id="score">Score : 0</div>

<script>

// Scene
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x87ceeb);

// Camera
const camera = new THREE.PerspectiveCamera(
60,
window.innerWidth/window.innerHeight,
0.1,
1000
);

camera.position.set(0,8,12);
camera.lookAt(0,0,-20);

// Renderer
const renderer = new THREE.WebGLRenderer({antialias:true});
renderer.setSize(window.innerWidth,window.innerHeight);
document.body.appendChild(renderer.domElement);

// Light
const light=new THREE.DirectionalLight(0xffffff,1.2);
light.position.set(10,20,10);
scene.add(light);

scene.add(new THREE.AmbientLight(0xffffff,0.5));

// Road

const road=new THREE.Mesh(
new THREE.BoxGeometry(8,0.2,250),
new THREE.MeshPhongMaterial({color:0x444444})
);

road.position.z=-100;
scene.add(road);

// Grass

const grass=new THREE.Mesh(
new THREE.BoxGeometry(60,0.1,250),
new THREE.MeshPhongMaterial({color:0x228B22})
);

grass.position.y=-0.15;
grass.position.z=-100;
scene.add(grass);

// Player

const player=new THREE.Group();

const body=new THREE.Mesh(
new THREE.BoxGeometry(1.2,0.6,2),
new THREE.MeshPhongMaterial({color:0x0066ff})
);

body.position.y=0.5;

const roof=new THREE.Mesh(
new THREE.BoxGeometry(0.8,0.5,1),
new THREE.MeshPhongMaterial({color:0xffffff})
);

roof.position.set(0,1,0);

player.add(body);
player.add(roof);

player.position.set(0,0,5);

scene.add(player);

// Controls

const keys={};

document.addEventListener("keydown",e=>keys[e.key]=true);
document.addEventListener("keyup",e=>keys[e.key]=false);

// Enemy Cars

const enemies=[];

function spawnEnemy(){

const enemy=new THREE.Group();

const b=new THREE.Mesh(
new THREE.BoxGeometry(1.2,0.6,2),
new THREE.MeshPhongMaterial({
color:Math.random()*0xffffff
})
);

b.position.y=0.5;

const r=new THREE.Mesh(
new THREE.BoxGeometry(0.8,0.5,1),
new THREE.MeshPhongMaterial({color:0xffffff})
);

r.position.y=1;

enemy.add(b);
enemy.add(r);

enemy.position.x=[-2.5,0,2.5][Math.floor(Math.random()*3)];
enemy.position.z=-180;

scene.add(enemy);

enemies.push(enemy);

}

setInterval(spawnEnemy,900);

// Score

let score=0;
let speed=0.8;
let gameOver=false;

function animate(){

requestAnimationFrame(animate);

if(gameOver){
renderer.render(scene,camera);
return;
}

if(keys["ArrowLeft"])
player.position.x-=0.15;

if(keys["ArrowRight"])
player.position.x+=0.15;

player.position.x=Math.max(-3,Math.min(3,player.position.x));

for(let i=enemies.length-1;i>=0;i--){

const e=enemies[i];

e.position.z+=speed;

if(e.position.z>15){

scene.remove(e);

enemies.splice(i,1);

score++;

document.getElementById("score").innerHTML="Score : "+score;

if(score%10==0)
speed+=0.08;

continue;

}

if(
Math.abs(player.position.x-e.position.x)<1 &&
Math.abs(player.position.z-e.position.z)<2
){

gameOver=true;

document.getElementById("score").innerHTML=
"GAME OVER<br>Score : "+score;

}

}

// Fake road movement

road.material.mapOffset=
new THREE.Vector2(0,performance.now()*0.001);

renderer.render(scene,camera);

}

animate();

window.addEventListener("resize",()=>{

camera.aspect=window.innerWidth/window.innerHeight;

camera.updateProjectionMatrix();

renderer.setSize(window.innerWidth,window.innerHeight);

});

</script>

</body>
</html>
</html>
