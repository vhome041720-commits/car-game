<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MusicHub</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#121212;
color:#fff;
}

header{
background:#000;
padding:15px 40px;
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
font-size:30px;
font-weight:bold;
color:#1DB954;
}

nav a{
color:white;
text-decoration:none;
margin-left:20px;
}

nav a:hover{
color:#1DB954;
}

.hero{
height:300px;
background:linear-gradient(to right,#1DB954,#191414);
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
}

.hero h1{
font-size:50px;
}

.hero p{
margin-top:10px;
font-size:18px;
}

.search{
margin-top:20px;
}

.search input{
padding:12px;
width:300px;
border:none;
border-radius:30px;
}

.search button{
padding:12px 20px;
border:none;
background:#1DB954;
color:white;
border-radius:30px;
cursor:pointer;
}

section{
padding:40px;
}

h2{
margin-bottom:20px;
color:#1DB954;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
gap:20px;
}

.card{
background:#1E1E1E;
border-radius:10px;
padding:15px;
text-align:center;
}

.card img{
width:100%;
height:170px;
object-fit:cover;
border-radius:10px;
}

.card h3{
margin:10px 0;
}

.card button{
padding:10px 20px;
background:#1DB954;
border:none;
color:white;
border-radius:20px;
cursor:pointer;
}

.languages{
display:flex;
flex-wrap:wrap;
gap:15px;
}

.languages div{
background:#1E1E1E;
padding:12px 20px;
border-radius:30px;
}

footer{
text-align:center;
padding:20px;
background:#000;
margin-top:40px;
}

</style>

</head>

<body>

<header>

<div class="logo">🎵 MusicHub</div>

